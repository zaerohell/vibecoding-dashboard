# ClickUp API Token
# Obtener en: ClickUp → Settings → Apps → API Token
CLICKUP_API_KEY=

# Linear API Key para sincronización ClickUp → Linear
# Obtener en: Linear → Settings → API → Personal API Keys → Create key
LINEAR_API_KEY=

# Linear Team ID (Proyectos CRM)
# Valor fijo: b1a97a6d-c20c-4606-b045-cef904de8db6
LINEAR_TEAM_ID=b1a97a6d-c20c-4606-b045-cef904de8db6

# Secret del webhook de ClickUp (opcional pero recomendado)
# Se genera automáticamente al registrar el webhook con register_webhook.py
# Copiarlo desde la respuesta del script → agregar aquí y en Vercel
CLICKUP_WEBHOOK_SECRET=

# URL de producción (Vercel la pone automáticamente)
NEXT_PUBLIC_APP_URL=http://localhost:3000
